FROM python:3.12-slim

RUN pip install -q camoufox[geoip] playwright && \
    playwright install-deps firefox 2>/dev/null || true && \
    apt-get install -y --no-install-recommends libgtk-3-0 libdbus-glib-1-2 libxt6 libasound2 libx11-xcb1 2>/dev/null || true && \
    rm -rf /var/lib/apt/lists/*

COPY test_camoufox.py /test_camoufox.py

CMD ["python", "/test_camoufox.py"]
